{
  "name": "aurelia2-aurafall",
  "version": "0.0.1",
  "description": "Virtual waterfall (masonry) plugin for Aurelia 2",
  "main": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "repository": "https://github.com/Vheissu/aurelia2-plugins",
  "author": "Dwayne Charrington <dwaynecharrington@gmail.com",
  "license": "MIT",
  "scripts": {
    "clean": "rimraf ./dist",
    "prebuild": "npm run clean",
    "build:ts": "tsc",
    "build:other": "cpx \"./src/**/*.css\" ./dist",
    "build": "npm run build:ts && npm run build:other",
    "watch:ts": "tsc --watch --preserveWatchOutput",
    "watch:other": "cpx \"./src/**/*.css\" ./dist --watch",
    "test:debug": "cross-env DEBUG=true npm run test",
    "test:watch": "cross-env DEV=true npm run test",
    "test": "jest"
  },
  "dependencies": {},
  "devDependencies": {
    "aurelia": "^2.0.0-rc.0"
  },
  "peerDependencies": {
    "aurelia": ">=2.0.0-rc.0"
  }
}
